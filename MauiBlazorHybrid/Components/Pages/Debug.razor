@page "/debug"
@using System.Text.Json
@using System.IO
@inject IJSRuntime JSRuntime

<h3>Debug Information</h3>

<div class="debug-section">
    @if (string.IsNullOrEmpty(_errorMessage))
    {
        @if (string.IsNullOrEmpty(_jsonContent))
        {
                    <div class="alert alert-info">Loading JSON content...</div>
        }
        else
        {
                    <div class="json-display">
                        <pre>@_formattedJson</pre>
                    </div>
        }
    }
    else
    {
            <div class="alert alert-danger">@_errorMessage</div>
    }
</div>

<div class="debug-section">
    <div class="log-header">
        <h4>Log Content</h4>
        <button class="btn btn-danger" @onclick="ClearLogFile">Clear Log</button>
    </div>
    
    @if (string.IsNullOrEmpty(_logErrorMessage))
    {
        @if (string.IsNullOrEmpty(_logContent))
        {
            <div class="alert alert-info">Loading log content...</div>
        }
        else
        {
            <div class="log-display">
                <pre>@_logContent</pre>
            </div>
        }
    }
    else
    {
        <div class="alert alert-danger">@_logErrorMessage</div>
    }
</div>

<style>
    .debug-section {
        margin: 20px 0;
    }
    .json-display {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        padding: 15px;
        overflow-x: auto;
    }
    pre {
        margin: 0;
        white-space: pre-wrap;
        word-wrap: break-word;
    }
</style>

@code {
    private string _jsonContent = string.Empty;
    private string _formattedJson = string.Empty;
    private string _errorMessage = string.Empty;

    private string _logContent = string.Empty;
    private string _logErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadJsonContent();
        await LoadLogContent();
    }

    private async Task LoadJsonContent()
    {
        try
        {
            var filePath = Path.Combine(FileSystem.AppDataDirectory, "pills.json");

            if (File.Exists(filePath))
            {
                _jsonContent = await File.ReadAllTextAsync(filePath);

                // Format JSON for better readability
                var jsonDocument = JsonDocument.Parse(_jsonContent);
                var options = new JsonSerializerOptions { WriteIndented = true };
                _formattedJson = JsonSerializer.Serialize(jsonDocument, options);
            }
            else
            {
                _errorMessage = "pills.json file not found in AppDataDirectory";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading JSON file: {ex.Message}";
        }
    }

    private async Task LoadLogContent()
    {
        try
        {
            // Load debug.log
            var logFilePath = Path.Combine(FileSystem.AppDataDirectory, "debug.log");

            if (File.Exists(logFilePath))
            {
                _logContent = await File.ReadAllTextAsync(logFilePath);
            }
            else
            {
                _logErrorMessage = "debug.log file not found in AppDataDirectory";
            }
        }
        catch (Exception ex)
        {
            _logErrorMessage = $"Error loading log file: {ex.Message}";
        }
    }

    private async Task ClearLogFile()
    {
        try
        {
            var logFilePath = Path.Combine(FileSystem.AppDataDirectory, "debug.log");

            if (File.Exists(logFilePath))
            {
                // Clear the file by writing an empty string to it
                await File.WriteAllTextAsync(logFilePath, string.Empty);

                // Reload the log content to show the empty file
                _logContent = string.Empty;
                _logErrorMessage = string.Empty;
            }
            else
            {
                _logErrorMessage = "debug.log file not found in AppDataDirectory";
            }
        }
        catch (Exception ex)
        {
            _logErrorMessage = $"Error clearing log file: {ex.Message}";
        }
    }
}
