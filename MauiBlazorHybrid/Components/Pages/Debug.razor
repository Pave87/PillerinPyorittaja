@page "/debug"
@using System.Text.Json
@using System.IO
@using CommunityToolkit.Maui.Storage
@inject IJSRuntime JSRuntime

<h3>Debug Information</h3>

<div class="debug-section">
    @if (string.IsNullOrEmpty(_errorMessage))
    {
        @if (string.IsNullOrEmpty(_jsonContent))
        {
                    <div class="alert alert-info">Loading JSON content...</div>
        }
        else
        {
                    <div class="json-display">
                        <pre>@_formattedJson</pre>
                    </div>
        }
    }
    else
    {
            <div class="alert alert-danger">@_errorMessage</div>
    }
</div>

<div class="debug-section">
    <h4>Debug Log Files</h4>
    @if (_logFiles.Count == 0)
    {
            <div class="alert alert-info">No debug log files found.</div>
    }
    else
    {
            <ul>
            @foreach (var logFile in _logFiles)
            {
                        <li>
                            <strong>@Path.GetFileName(logFile)</strong>
                            <button class="btn btn-primary" @onclick="() => OpenLogFile(logFile)">Open</button>
                            <button class="btn btn-secondary" @onclick="() => SaveLogFile(logFile)">Save</button>
                        </li>
            }
            </ul>
    }
</div>

<!-- Custom Modal Dialog -->
<div id="customDialog" class="modal-overlay" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h4 id="dialogTitle"></h4>
            <span class="close-button" onclick="closeCustomDialog()">&times;</span>
        </div>
        <div class="modal-body">
            <pre id="dialogContent"></pre>
        </div>
    </div>
</div>

<style>
    .debug-section {
        margin: 20px 0;
    }
    .json-display {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        padding: 15px;
        overflow-x: auto;
    }
    pre {
        margin: 0;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    /* Custom Modal Styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0,0,0,0.5);
        z-index: 1000;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background-color: white;
        border-radius: 8px;
        width: 90%;
        max-width: 90%;
        max-height: 90vh;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        display: flex;
        flex-direction: column;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 15px;
        border-bottom: 1px solid #dee2e6;
    }

    .modal-body {
        padding: 15px;
        overflow-y: auto;
        max-height: calc(90vh - 60px);
    }

    .close-button {
        font-size: 24px;
        cursor: pointer;
        color: #555;
    }

    .close-button:hover {
        color: black;
    }
</style>

@code {
    private string _jsonContent = string.Empty;
    private string _formattedJson = string.Empty;
    private string _errorMessage = string.Empty;

    private List<string> _logFiles = new();
    private string _logErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadJsonContent();
        LoadLogFiles();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeJavaScript();
        }
    }

    private async Task InitializeJavaScript()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", @"
                window.showCustomDialog = function(title, content) {
                    document.getElementById('dialogTitle').textContent = title;
                    document.getElementById('dialogContent').textContent = content;
                    document.getElementById('customDialog').style.display = 'flex';
                };

                window.closeCustomDialog = function() {
                    document.getElementById('customDialog').style.display = 'none';
                };
            ");

        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to initialize JavaScript";

        }
    }

    private async Task LoadJsonContent()
    {
        try
        {
            var filePath = Path.Combine(FileSystem.AppDataDirectory, "pills.json");

            if (File.Exists(filePath))
            {
                _jsonContent = await File.ReadAllTextAsync(filePath);

                // Format JSON for better readability
                var jsonDocument = JsonDocument.Parse(_jsonContent);
                var options = new JsonSerializerOptions { WriteIndented = true };
                _formattedJson = JsonSerializer.Serialize(jsonDocument, options);
            }
            else
            {
                _errorMessage = "data.json file not found in AppDataDirectory";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading JSON file: {ex.Message}";

        }
    }

    private void LoadLogFiles()
    {
        try
        {
            var logDirectory = FileSystem.AppDataDirectory;
            _logFiles = Directory.GetFiles(logDirectory, "debug*.log").ToList();
        }
        catch (Exception ex)
        {
            _logErrorMessage = $"Error loading log files: {ex.Message}";

        }
    }

    private async Task OpenLogFile(string filePath)
    {
        try
        {
            if (File.Exists(filePath))
            {
                var content = await File.ReadAllTextAsync(filePath);
                var fileName = Path.GetFileName(filePath);

                await JSRuntime.InvokeVoidAsync("showCustomDialog", fileName, content);
            }
            else
            {
                _logErrorMessage = $"File not found: {filePath}";

            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error opening log file: {ex.Message}";

        }
    }

    private async Task SaveLogFile(string filePath)
    {
        try
        {
            // Check if file exists
            if (!File.Exists(filePath))
            {
                _errorMessage = $"File not found: {filePath}";
                return;
            }

            // Read the file content
            var fileContent = await File.ReadAllTextAsync(filePath);

            // Get the filename
            var fileName = Path.GetFileName(filePath);

            // Create file type based on extension (logs are text files)
            var fileType = new FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>>
            {
                { DevicePlatform.Android, new[] { "text/plain" } }
            });

            using FileStream fileStream = File.OpenRead(filePath);

            // Save the file to a location accessible by the user
            var result = await FileSaver.SaveAsync(filePath, fileName, fileStream, new CancellationTokenSource().Token);

            Thread.Sleep(1000); // Simulate some delay

            if (result.IsSuccessful)
            {
                // Show success message using JS alert
                await JSRuntime.InvokeVoidAsync("alert", $"Log file saved successfully to: {result.FilePath}");
            }
            else
            {
                //_errorMessage = $"Failed to save log file: {result.Exception?.Message ?? "Unknown error"}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error saving log file: {ex.Message}";
        }
    }
}
