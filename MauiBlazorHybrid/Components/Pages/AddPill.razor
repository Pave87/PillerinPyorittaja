@page "/addpill"
@page "/addpill/{Id:int?}"
@using MauiBlazorHybrid.Models
@using MauiBlazorHybrid.Services
@inject IPillService PillService
@inject NavigationManager NavigationManager

<h1>@(Id.HasValue ? "Edit Pill" : "Add a New Pill")</h1>

<form>
    <label for="pillName">Pill Name:</label>
    <input id="pillName" type="text" @bind="PillName" />

    <h3>Dosages</h3>
    @foreach (var (dosage, index) in Dosages.Select((d, i) => (d, i)))
    {
        <div class="dosage-row">
            <label>Time:</label>
            <input type="time" 
                   @bind="dosage.Time"
                   @bind:event="oninput" />

            <label>Repetition:</label>
            <input type="number" @bind="dosage.Repetition" style="width: 40px;" />

            <label>Frequency:</label>
            <select @bind="dosage.Frequency">
                <option value="Days">Days</option>
                <option value="Weeks">Weeks</option>
            </select>

            @if (dosage.Frequency == "Weeks")
            {
                <div class="weekday-selection">
                    <label>Select Weekdays:</label>
                    @foreach (var day in WeekDays)
                    {
                        <label class="weekday-checkbox">
                            <input type="checkbox" 
                                   checked="@(dosage.SelectedDays?.Contains(day) ?? false)"
                                   @onchange="@(e => ToggleWeekday(dosage, day, (bool)e.Value))" />
                            @day
                        </label>
                    }
                </div>
            }

            @if (index == Dosages.Count - 1)
            {
                <button type="button" @onclick="AddNewDosageRow">Add Another Dosage</button>
            }
        </div>
    }

    @if (!Dosages.Any())
    {
        <button type="button" @onclick="AddNewDosageRow">Add Dosage</button>
    }

    <button type="button" @onclick="HandleSubmit">@(Id.HasValue ? "Save Changes" : "Add Pill")</button>
    <button type="button" @onclick="Cancel">Cancel</button>
</form>

<style>
    .weekday-selection {
        margin: 10px 0;
    }
    .weekday-checkbox {
        margin-right: 10px;
    }
    .monthday-selection {
        margin: 10px 0;
    }
</style>

@code {
    [Parameter]
    public int? Id { get; set; }

    private string PillName { get; set; } = string.Empty;
    private List<PillDosage> Dosages { get; set; } = new();
    private readonly string[] WeekDays = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Id.HasValue)
            {
                var pill = await PillService.GetPillAsync(Id.Value);
                if (pill != null)
                {
                    PillName = pill.Name;
                    Dosages = pill.Dosages.Select(d => new PillDosage
                    {
                        Id = d.Id,
                        PillId = d.PillId,
                        Time = d.Time,
                        Repetition = d.Repetition,
                        Frequency = d.Frequency,
                        SelectedDays = d.SelectedDays
                    }).ToList();
                }
                else
                {
                    NavigationManager.NavigateTo("/pills");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading pill: {ex.Message}");
            NavigationManager.NavigateTo("/pills");
        }
    }

    private void AddNewDosageRow()
    {
        Dosages.Add(new PillDosage { 
            Frequency = "Days",
            SelectedDays = new List<string>(),
                Repetition = 1
        });
        StateHasChanged();
    }

    private void ToggleWeekday(PillDosage dosage, string day, bool isChecked)
    {
        if (dosage.SelectedDays == null)
        {
            dosage.SelectedDays = new List<string>();
        }

        if (isChecked && !dosage.SelectedDays.Contains(day))
        {
            dosage.SelectedDays.Add(day);
        }
        else if (!isChecked && dosage.SelectedDays.Contains(day))
        {
            dosage.SelectedDays.Remove(day);
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(PillName) || !Dosages.Any())
                return;

            if (Id.HasValue)
            {
                var existingPill = await PillService.GetPillAsync(Id.Value);
                if (existingPill != null)
                {
                    existingPill.Name = PillName;
                    existingPill.Dosages = Dosages;
                    await PillService.UpdatePillAsync(existingPill);
                }
            }
            else
            {
                var newPill = new Pill
                {
                    Name = PillName,
                    Dosages = Dosages
                };
                await PillService.AddPillAsync(newPill);
            }

            NavigationManager.NavigateTo("/pills");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving pill: {ex.Message}");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/pills");
    }
}
