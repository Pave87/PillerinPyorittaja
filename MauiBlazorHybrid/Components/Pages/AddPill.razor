@page "/addpill"
@page "/addpill/{Id:int?}"
@using MauiBlazorHybrid.Models
@using MauiBlazorHybrid.Services
@using MauiBlazorHybrid.Extensions
@inject IPillService PillService
@inject NavigationManager NavigationManager
@inherits LocalizeComponent

<h1>@L(Id.HasValue ? "EditPill" : "AddNewPill")</h1>

<form>
    <div class="form-group">
        <label for="pillName">@L("PillName"):</label>
        <input id="pillName" type="text" @bind="PillName" class="form-control" />
    </div>

    <div class="form-group">
        <label for="pillQuantity">@L("QuantityLeft"):</label>
        <input id="pillQuantity" type="number" @bind="PillQuantity" min="0" step="0.5" class="form-control" />
    </div>

    <div class="form-group">
        <label for="Unit">@L("Unit"):</label>
        <input id="Unit" type="text" @bind="Unit" class="form-control" />
    </div>

    <div class="form-group">
        <label for="amountPerPackage">@L("PillsPerPackage"):</label>
        <input id="amountPerPackage" type="number" @bind="AmountPerPackage" min="1" step="1" class="form-control" />
    </div>

    <h3>@L("Dosages")</h3>
    @foreach (var (dosage, index) in Dosages.Select((d, i) => (d, i)))
    {
        <div class="dosage-row">
            <div class="form-group">
                <label>@L("Time"):</label>
                <input type="time"
                       @bind="dosage.Time"
                       @bind:event="oninput"
                       class="form-control" />
            </div>

            <div class="form-group">
                <label>@L("AmountTaken"):</label>
                <input type="number" @bind="dosage.AmountTaken" class="form-control" style="width: 100px;" step="0.5" min="0.5" />
            </div>

            <div class="form-group">
                <label>@L("Repetition"):</label>
                <input type="number" @bind="dosage.Repetition" class="form-control" style="width: 80px;" min="1" />
            </div>

            <div class="form-group">
                <label>@L("Frequency"):</label>
                <select @bind="dosage.Frequency" class="form-control">
                    <option value="Days">@L("Days")</option>
                    <option value="Weeks">@L("Weeks")</option>
                </select>
            </div>

            @if (dosage.Frequency == "Weeks")
            {
                <div class="weekday-selection">
                    <label>@L("SelectWeekdays"):</label>
                    <div class="weekday-checkboxes">
                        @foreach (var day in WeekDays)
                        {
                            <label class="weekday-checkbox">
                                <input type="checkbox"
                                       checked="@(dosage.SelectedDays?.Contains(day) ?? false)"
                                       @onchange="@(e => ToggleWeekday(dosage, day, (bool)e.Value))" />
                                @L(day)
                            </label>
                        }
                    </div>
                </div>
            }

            @if (index == Dosages.Count - 1)
            {
                <button type="button" class="btn-add-dosage" @onclick="AddNewDosageRow">@L("AddAnotherDosage")</button>
            }
        </div>
    }

    @if (!Dosages.Any())
    {
        <button type="button" class="btn-add-dosage" @onclick="AddNewDosageRow">@L("AddDosage")</button>
    }

    <div class="form-actions">
        <button type="button" class="btn-submit" @onclick="HandleSubmit">@L(Id.HasValue ? "SaveChanges" : "AddPill")</button>
        <button type="button" class="btn-cancel" @onclick="Cancel">@L("Cancel")</button>
    </div>
</form>

<style>
    form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 550px;
        margin: 0 auto;
        padding: 1rem;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    label {
        display: block;
        font-weight: bold;
        margin-bottom: 0.5rem;
    }

    .form-control {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 1rem;
    }

    .dosage-row {
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
        background-color: #f9f9f9;
    }

    .weekday-selection {
        margin-top: 1rem;
    }

    .weekday-checkboxes {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .weekday-checkbox {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        margin-right: 1rem;
    }

    .btn-add-dosage {
        display: block;
        padding: 0.5rem 1rem;
        background-color: #17a2b8;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        margin: 1rem 0;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn-submit, .btn-cancel {
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 500;
    }

    .btn-submit {
        background-color: #28a745;
        color: white;
    }

    .btn-cancel {
        background-color: #6c757d;
        color: white;
    }

    button:hover {
        opacity: 0.9;
    }
</style>

@code {
    [Parameter]
    public int? Id { get; set; }

    private string PillName { get; set; } = string.Empty;
    private double PillQuantity { get; set; } = 0;
    private double AmountPerPackage { get; set; } = 1;
    private string Unit { get; set; } = string.Empty;
    private List<PillDosage> Dosages { get; set; } = new();
    private readonly string[] WeekDays = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
    private int _nextDosageId = 1; // Track next dosage ID

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Id.HasValue)
            {
                var pill = await PillService.GetPillAsync(Id.Value);
                if (pill != null)
                {
                    PillName = pill.Name;
                    PillQuantity = pill.Quantity;
                    AmountPerPackage = pill.AmountPerPackage;
                    Unit = pill.Unit;
                    Dosages = pill.Dosages.Select(d => new PillDosage
                        {
                            Id = d.Id,
                            PillId = d.PillId,
                            Time = d.Time,
                            Repetition = d.Repetition,
                            Frequency = d.Frequency,
                            SelectedDays = d.SelectedDays,
                            AmountTaken = d.AmountTaken
                        }).ToList();

                    // Set the next dosage ID based on existing dosages
                    _nextDosageId = Dosages.Any() ? Dosages.Max(d => d.Id) + 1 : 1;
                }
                else
                {
                    NavigationManager.NavigateTo("/pills");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading pill: {ex.Message}");
            NavigationManager.NavigateTo("/pills");
        }
    }

    private void AddNewDosageRow()
    {
        Dosages.Add(new PillDosage
            {
                Id = _nextDosageId++, // Assign incremental ID
                PillId = Id ?? 0, // Set PillId if we're editing an existing pill
                Frequency = "Days",
                SelectedDays = new List<string>(),
                Repetition = 1,
                AmountTaken = 1.0
            });
        StateHasChanged();
    }

    private void ToggleWeekday(PillDosage dosage, string day, bool isChecked)
    {
        if (dosage.SelectedDays == null)
        {
            dosage.SelectedDays = new List<string>();
        }

        if (isChecked && !dosage.SelectedDays.Contains(day))
        {
            dosage.SelectedDays.Add(day);
        }
        else if (!isChecked && dosage.SelectedDays.Contains(day))
        {
            dosage.SelectedDays.Remove(day);
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(PillName) || !Dosages.Any())
                return;

            if (Id.HasValue)
            {
                var existingPill = await PillService.GetPillAsync(Id.Value);
                if (existingPill != null)
                {
                    existingPill.Name = PillName;
                    existingPill.Quantity = PillQuantity;
                    existingPill.AmountPerPackage = AmountPerPackage;
                    existingPill.Unit = Unit;

                    // Ensure all dosages have the correct PillId
                    foreach (var dosage in Dosages)
                    {
                        dosage.PillId = existingPill.Id;
                    }

                    existingPill.Dosages = Dosages;
                    await PillService.UpdatePillAsync(existingPill);
                }
            }
            else
            {
                var newPill = new Pill
                    {
                        Name = PillName,
                        Quantity = PillQuantity,
                        AmountPerPackage = AmountPerPackage,
                        Unit = Unit,
                        Dosages = new List<PillDosage>() // Initialize with empty list
                    };

                // Add the pill first to get its ID
                var savedPill = await PillService.AddPillAsync(newPill);

                // Update dosage IDs and PillId
                foreach (var dosage in Dosages)
                {
                    dosage.PillId = savedPill.Id;
                }

                // Update the pill with dosages
                savedPill.Dosages = Dosages;
                await PillService.UpdatePillAsync(savedPill);
            }

            NavigationManager.NavigateTo("/pills");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving pill: {ex.Message}");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/pills");
    }
}
