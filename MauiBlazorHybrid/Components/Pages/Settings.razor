        border: 1px solid var(--card-border);
        border-radius: 8px;
        padding: 1.5rem;
        background-color: var(--card-background);
        box-shadow: 0 2px 4px var(--card-shadow);
    }

    .setting-card h2 {
        margin-top: 0;
        color: var(--heading-text);
        font-size: 1.5rem;
        font-weight: 500;
    }

    .setting-card p {
        color: var(--secondary-text);
    }

    .language-selector-container,
    .theme-selector-container {
        margin-top: 1rem;
    }

    .language-dropdown {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid var(--card-border);
        border-radius: 4px;
        font-size: 1rem;
        background-color: var(--panel-background-alt);
        color: var(--body-text);
    }

    .setting-info {
        color: var(--secondary-text);
        font-size: 0.9rem;
        padding: 0.5rem;
    }

    .theme-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    .download-btn {
        padding: 0.75rem 1.5rem;
        background-color: var(--button-confirm-background);
        color: #fff;
        border: none;
        border-radius: 4px;
        font-size: 1rem;
        cursor: pointer;
    }

    .download-btn:hover {
        background-color: var(--button-confirm-background-hover);
    }

    .delete-theme-btn {
        padding: 0.75rem 1.5rem;
        background-color: var(--button-delete-background);
        color: #fff;
        border: none;
        border-radius: 4px;
        font-size: 1rem;
        cursor: pointer;
    }

    .backup-field {
        margin-bottom: 0.75rem;
    }

    .backup-field label {
        display: block;
        margin-bottom: 0.25rem;
        color: var(--secondary-text);
        font-size: 0.9rem;
    }

    .backup-input-row {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .backup-input {
        flex: 1;
        padding: 0.75rem;
        border: 1px solid var(--card-border);
