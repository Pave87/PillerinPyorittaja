</style>

@code {
    private List<string> _availableThemes = new() { "auto", "light", "dark" };

    private string SelectedTheme
    {
        get => ThemeService.CurrentTheme;
        set
        {
            if (value != ThemeService.CurrentTheme)
            {
                _ = ThemeService.SetThemeAsync(value);
            }
        }
    }

    private string SelectedCulture
    {
        get => LocalizationService.CurrentCulture;
        set
        {
            if (value != LocalizationService.CurrentCulture)
            {
                LocalizationService.SetCultureAsync(value);
            }
        }
    }

    private bool IsDebugEnabled
    {
        get => SettingsService.IsDebugEnabled;
        set
        {
            SettingsService.IsDebugEnabled = value;
        }
    }

    private bool ShowTodayTaken
    {
        get => SettingsService.ShowTodayTaken;
        set
        {
            SettingsService.ShowTodayTaken = value;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _availableThemes = await ThemeService.GetAvailableThemesAsync();

        // Load backup settings
        _serverUrl = SettingsService.BackupServerUrl;
        _deviceId = SettingsService.DeviceId;
        _accountId = SettingsService.AccountId;
        _password = SettingsService.BackupPassword;
        _autoBackupEnabled = SettingsService.AutoBackupEnabled;
        _backupOnChangeEnabled = SettingsService.BackupOnChangeEnabled;

        if (!string.IsNullOrWhiteSpace(_serverUrl))
        {
            _isNonPrivateServer = await BackupService.IsNonPrivateServerAsync();
        }
    }

    private string GetThemeDisplayName(string theme)
    {
        return theme switch
        {
            "auto" => L("Theme_Auto"),
            "light" => L("Theme_Light"),
            "dark" => L("Theme_Dark"),
            _ => theme
        };
    }

    private async Task ExportThemeAsync()
    {
        try
        {
            var resolvedTheme = ThemeService.CurrentTheme == "auto" ? ThemeService.ResolvedTheme : ThemeService.CurrentTheme;
            var stream = await ThemeService.ExportThemeAsync(resolvedTheme);
            if (stream != null)
            {
                var result = await FileSaver.Default.SaveAsync($"{resolvedTheme}.json", stream, default);
                if (result.IsSuccessful)
                {
                    LoggerService.Log($"Theme exported to: {result.FilePath}");
                }
                await stream.DisposeAsync();
            }
        }
        catch (Exception ex)
        {
            LoggerService.Log($"Error exporting theme: {ex.Message}");
        }
    }

    private async Task ImportThemeAsync()
    {
        try
        {
            var fileResult = await FilePicker.PickAsync(new PickOptions
            {
                PickerTitle = L("Import_Theme"),
                FileTypes = new FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>>
                {
                    { DevicePlatform.Android, new[] { "application/json" } },
                    { DevicePlatform.iOS, new[] { "public.json" } },
                    { DevicePlatform.WinUI, new[] { ".json" } }
                })
            });

            if (fileResult != null)
            {
                using var stream = await fileResult.OpenReadAsync();
                var themeName = await ThemeService.ImportThemeAsync(stream, fileResult.FileName);
                if (themeName != null)
                {
                    _availableThemes = await ThemeService.GetAvailableThemesAsync();
                    await ThemeService.SetThemeAsync(themeName);
                    StateHasChanged();
                    LoggerService.Log($"Theme imported: {themeName}");
                }
            }
        }
        catch (Exception ex)
        {
            LoggerService.Log($"Error importing theme: {ex.Message}");
        }
    }

    private async Task DeleteCustomThemeAsync()
    {
        try
        {
            var deleted = await ThemeService.DeleteCustomThemeAsync(SelectedTheme);
            if (deleted)
            {
                _availableThemes = await ThemeService.GetAvailableThemesAsync();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            LoggerService.Log($"Error deleting theme: {ex.Message}");
        }
    }

    #region Backup Fields

    private string _serverUrl = string.Empty;
    private string _deviceId = string.Empty;
    private string _accountId = string.Empty;
    private string _password = string.Empty;
    private bool? _connectionStatus;
    private bool _isTesting;
    private bool _isBackingUp;
    private bool? _backupStatus;
    private bool _isRestoring;
    private string? _pendingRestoreDeviceId;
    private string? _pendingRestoreBackupId;
    private RestorePreview? _restorePreview;
    private bool? _restoreStatus;
    private List<BackupInfo>? _backups;
    private List<string>? _devices;
    private string _selectedSyncDevice = string.Empty;
    private bool _autoBackupEnabled;
    private bool _backupOnChangeEnabled;
    private bool _isNonPrivateServer;

    #endregion

    private bool IsBackupConfigured =>
        !string.IsNullOrWhiteSpace(_serverUrl) &&
        !string.IsNullOrWhiteSpace(_deviceId);

    private int AutoBackupInterval
    {
        get => SettingsService.AutoBackupIntervalMinutes;
        set
        {
            SettingsService.AutoBackupIntervalMinutes = value;
            if (_autoBackupEnabled)
            {
                BackupService.StartAutoBackup();
            }
        }
    }

    private async Task SaveServerUrl()
    {
        SettingsService.BackupServerUrl = _serverUrl;
        _connectionStatus = null;
        _backupStatus = null;
        _isNonPrivateServer = await BackupService.IsNonPrivateServerAsync();
        StateHasChanged();
    }

    private void SaveDeviceId()
    {
        SettingsService.DeviceId = _deviceId;
    }

    private void SaveAccountId()
    {
        SettingsService.AccountId = _accountId;
    }

    private void SavePassword()
    {
        SettingsService.BackupPassword = _password;
    }

    private async Task TestConnectionAsync()
    {
        _isTesting = true;
        _connectionStatus = null;
        StateHasChanged();

        try
        {
            _connectionStatus = await BackupService.TestConnectionAsync();
        }
        catch
        {
            _connectionStatus = false;
        }
        finally
        {
            _isTesting = false;
            StateHasChanged();
        }
    }

    private async Task BackupNowAsync()
    {
        _isBackingUp = true;
        _backupStatus = null;
        StateHasChanged();

        try
        {
            // Auto-register account if needed
            if (string.IsNullOrWhiteSpace(SettingsService.AccountId))
            {
                var accountId = await BackupService.RegisterAccountAsync();
                if (string.IsNullOrEmpty(accountId))
                {
                    _backupStatus = false;
                    return;
                }
                _accountId = accountId;
            }

            _backupStatus = await BackupService.BackupAsync();

            // Refresh device list after backup
            _devices = await BackupService.ListDevicesAsync();
        }
        catch
        {
            _backupStatus = false;
        }
        finally
        {
            _isBackingUp = false;
            StateHasChanged();
        }
    }

    private async Task ListBackupsAsync()
    {
        _backups = await BackupService.ListBackupsAsync();

        // Also fetch from other devices
        _devices = await BackupService.ListDevicesAsync();
        if (_devices != null)
        {
            foreach (var device in _devices.Where(d => d != _deviceId))
            {
                var deviceBackups = await BackupService.ListBackupsAsync(device);
                _backups.AddRange(deviceBackups);
            }
            _backups = _backups.OrderByDescending(b => b.Timestamp).ToList();
        }
    }

    #region Restore Methods

    /// <summary>
    /// Starts a restore from a specific backup in the backup list.
    /// </summary>
    private async Task BeginRestore(string deviceId, string backupId)
    {
        _pendingRestoreDeviceId = deviceId;
        _pendingRestoreBackupId = backupId;
        await PreviewRestoreAsync();
    }

    /// <summary>
    /// Starts a restore of the latest backup from the current device.
    /// </summary>
    private async Task RestoreLatestAsync()
    {
        _pendingRestoreDeviceId = null;
        _pendingRestoreBackupId = null;
        await PreviewRestoreAsync();
    }

    /// <summary>
    /// Starts a restore of the latest backup from a selected sync device.
    /// </summary>
    private async Task SyncFromDeviceAsync()
    {
        if (string.IsNullOrEmpty(_selectedSyncDevice)) return;

        _pendingRestoreDeviceId = _selectedSyncDevice;
        _pendingRestoreBackupId = null;
        await PreviewRestoreAsync();
    }

    /// <summary>
    /// Downloads the backup and builds a preview diff against current data.
    /// If the restore is safe (additive only), applies it immediately.
    /// If destructive changes are detected, shows a confirmation dialog.
    /// </summary>
    private async Task PreviewRestoreAsync()
    {
        _isRestoring = true;
        _restorePreview = null;
        _restoreStatus = null;
        StateHasChanged();

        try
        {
            RestorePreview? preview;
            if (_pendingRestoreBackupId != null && _pendingRestoreDeviceId != null)
            {
                preview = await BackupService.PreviewRestoreAsync(_pendingRestoreDeviceId, _pendingRestoreBackupId);
            }
            else if (_pendingRestoreDeviceId != null)
            {
                preview = await BackupService.PreviewRestoreLatestAsync(_pendingRestoreDeviceId);
            }
            else
            {
                preview = await BackupService.PreviewRestoreLatestAsync();
            }

            if (preview == null)
            {
                _restoreStatus = false;
                return;
            }

            if (preview.IsIdentical)
            {
                // Nothing to do — show info message
                _restorePreview = preview;
                return;
            }

            if (!preview.HasDestructiveChanges)
            {
                // Safe restore — apply immediately without confirmation
                var success = await BackupService.ApplyRestoreAsync(preview);
                _restoreStatus = success;
                return;
            }

            // Destructive changes — show confirmation dialog
            _restorePreview = preview;
        }
        catch
        {
            _restoreStatus = false;
        }
        finally
        {
            _isRestoring = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// User confirmed the destructive restore — apply it.
    /// </summary>
    private async Task ApplyRestoreAsync()
    {
        if (_restorePreview == null) return;

        _isRestoring = true;
        StateHasChanged();

        try
        {
            var success = await BackupService.ApplyRestoreAsync(_restorePreview);
            _restoreStatus = success;
        }
        catch
        {
            _restoreStatus = false;
        }
        finally
        {
            _restorePreview = null;
            _isRestoring = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// User cancelled the destructive restore.
    /// </summary>
    private void CancelRestore()
    {
        _restorePreview = null;
    }

    #endregion

    private void ToggleAutoBackup(ChangeEventArgs e)
    {
        _autoBackupEnabled = (bool)(e.Value ?? false);
        SettingsService.AutoBackupEnabled = _autoBackupEnabled;

        if (_autoBackupEnabled)
        {
            BackupService.StartAutoBackup();
        }
        else
        {
            BackupService.StopAutoBackup();
        }
    }

    private void ToggleBackupOnChange(ChangeEventArgs e)
    {
        _backupOnChangeEnabled = (bool)(e.Value ?? false);
        SettingsService.BackupOnChangeEnabled = _backupOnChangeEnabled;
    }

    private async Task DownloadUserDataAsync()
    {
        try
        {
            string fileName = "userdata.json";
            string filePath = Path.Combine(FileSystem.Current.AppDataDirectory, fileName);

            if (!File.Exists(filePath))
            {
                LoggerService.Log("User data file not found: " + filePath);
                return;
            }

            using var fileStream = File.OpenRead(filePath);

            var result = await FileSaver.Default.SaveAsync(fileName, fileStream, default);

            if (result.IsSuccessful)
            {
                LoggerService.Log($"User data saved to: {result.FilePath}");
            }
            else
            {
                LoggerService.Log("User cancelled or failed to save user data.");
            }
        }
        catch (Exception ex)
        {
            LoggerService.Log(ex);
        }
    }
}
