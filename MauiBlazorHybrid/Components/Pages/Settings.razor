@page "/settings"
@using MauiBlazorHybrid.Services
@using MauiBlazorHybrid.Extensions
@using MauiBlazorHybrid.Models
@using CommunityToolkit.Maui.Storage
@inject ILocalizationService LocalizationService
@inject ISettingsService SettingsService
@inject IThemeService ThemeService
@inject ILoggerService LoggerService
@inject IBackupService BackupService
@inherits LocalizeComponent

<h1>@L("Settings")</h1>

<div class="settings-container">
    <div class="setting-card">
        <h2>@L("Theme")</h2>
        <p>@L("Select_Theme")</p>

        <div class="theme-selector-container">
            <select @bind="SelectedTheme" class="language-dropdown">
                @foreach (var theme in _availableThemes)
                {
                    <option value="@theme">@GetThemeDisplayName(theme)</option>
                }
            </select>
        </div>

        <div class="theme-actions">
            <button class="download-btn" @onclick="ExportThemeAsync">@L("Export_Theme")</button>
            <button class="download-btn" @onclick="ImportThemeAsync">@L("Import_Theme")</button>
            @if (!string.IsNullOrEmpty(SelectedTheme) && SelectedTheme != "auto" && SelectedTheme != "light" && SelectedTheme != "dark")
            {
                <button class="delete-theme-btn" @onclick="DeleteCustomThemeAsync">@L("Delete_Theme")</button>
            }
        </div>
    </div>

    <div class="setting-card">
        <h2>@L("Language")</h2>
        <p>@L("Select_Language")</p>

        <div class="language-selector-container">
            <select @bind="SelectedCulture" class="language-dropdown">
                <option value="en-US">English</option>
                <option value="fi-FI">Suomi</option>
            </select>
        </div>
    </div>

    <div class="setting-card">
        <h2>@L("Show_Today_Taken")</h2>
        <div class="setting-option">
            <label class="debug-checkbox-label">
                <input type="checkbox" @bind="ShowTodayTaken" />
                <span>@L("Show_Today_Taken_Description")</span>
            </label>
        </div>
    </div>

    <div class="setting-card">
        <h2>@L("Debug")</h2>
        <div class="setting-option">
            <label class="debug-checkbox-label">
                <input type="checkbox" @bind="IsDebugEnabled" />
                <span>@L("Debug_Mode")</span>
            </label>
        </div>
        <span>@L("Needs_Restart")</span>
    </div>

    <div class="setting-card">
        <h2>@L("Download_User_Data")</h2>
        <div class="setting-option">
            <button class="download-btn" @onclick="DownloadUserDataAsync">@L("Download_userdata_json")</button>
        </div>
        <span>@L("Download_userdata_json_description")</span>
    </div>

    <div class="setting-card">
        <h2>@L("Backup")</h2>

        <div class="backup-field">
            <label>@L("Backup_Server_Address")</label>
            <input type="text" class="backup-input" @bind="_serverUrl" @bind:after="SaveServerUrl" placeholder="192.168.1.100:5199" />
        </div>

        @if (_isNonPrivateServer)
        {
            <div class="backup-warning">
                <span>⚠️ @L("Backup_Non_Private_Warning")</span>
            </div>
        }

        <div class="backup-field">
            <label>@L("Backup_Device_Name")</label>
            <input type="text" class="backup-input" @bind="_deviceId" @bind:after="SaveDeviceId" placeholder="my-phone" />
        </div>

        <div class="backup-field">
            <label>@L("Backup_Account_Id")</label>
            <p class="backup-hint">@L("Backup_Account_Id_Description")</p>
            <input type="text" class="backup-input" @bind="_accountId" @bind:after="SaveAccountId" placeholder="" />
        </div>

        <div class="backup-field">
            <label>@L("Backup_Password")</label>
            <p class="backup-hint">@L("Backup_Password_Description")</p>
            <input type="password" class="backup-input" @bind="_password" @bind:after="SavePassword" placeholder="" />
        </div>

        <div class="backup-actions">
            <button class="download-btn" @onclick="TestConnectionAsync" disabled="@_isTesting">
                @L("Test_Connection")
            </button>
            @if (_connectionStatus == true)
            {
                <span class="backup-status backup-success">@L("Connection_Success")</span>
            }
            else if (_connectionStatus == false)
            {
                <span class="backup-status backup-fail">@L("Connection_Failed")</span>
            }
        </div>

        <div class="backup-actions">
            <button class="download-btn" @onclick="BackupNowAsync" disabled="@(_isBackingUp || !IsBackupConfigured)">
                @(_isBackingUp ? L("Backing_Up") : L("Backup_Now"))
            </button>
            @if (_backupStatus == true)
            {
                <span class="backup-status backup-success">@L("Backup_Success")</span>
            }
            else if (_backupStatus == false)
            {
                <span class="backup-status backup-fail">@L("Backup_Failed")</span>
            }
        </div>

        <hr class="backup-divider" />

        <div class="backup-actions">
            <button class="download-btn" @onclick="RestoreLatestAsync" disabled="@(_isRestoring || !IsBackupConfigured)">
                @(_isRestoring ? L("Restoring") : L("Restore_Latest"))
            </button>
            <button class="download-btn" @onclick="ListBackupsAsync" disabled="@(!IsBackupConfigured)">
                @L("List_Backups")
            </button>
        </div>

        @if (_restorePreview != null)
        {
            <div class="backup-confirm">
                @if (_restorePreview.HasDestructiveChanges)
                {
                    <p>@L("Restore_Warning")</p>
                    @if (_restorePreview.RemovedProducts.Count > 0)
                    {
                        <p>@L("Restore_Products_Lost"): @string.Join(", ", _restorePreview.RemovedProducts)</p>
                    }
                    @if (_restorePreview.LostHistoryEntries > 0)
                    {
                        <p>@L("Restore_History_Lost"): @_restorePreview.LostHistoryEntries</p>
                    }
                    @if (_restorePreview.AddedProducts.Count > 0)
                    {
                        <p>@L("Restore_Products_Added"): @string.Join(", ", _restorePreview.AddedProducts)</p>
                    }
                    @if (_restorePreview.ModifiedProducts.Count > 0)
                    {
                        <p>@L("Restore_Products_Modified"): @string.Join(", ", _restorePreview.ModifiedProducts)</p>
                    }
                    <button class="download-btn" @onclick="ApplyRestoreAsync">@L("Yes")</button>
                    <button class="delete-theme-btn" @onclick="CancelRestore">@L("No")</button>
                }
                else if (_restorePreview.IsIdentical)
                {
                    <p>@L("Restore_Identical")</p>
                    <button class="delete-theme-btn" @onclick="CancelRestore">@L("OK")</button>
                }
            </div>
        }

        @if (_restoreStatus != null)
        {
            <div class="backup-confirm">
                <p>@(_restoreStatus == true ? L("Restore_Success") : L("Restore_Failed"))</p>
                <button class="delete-theme-btn" @onclick="() => _restoreStatus = null">@L("OK")</button>
            </div>
        }

        @if (_backups != null && _backups.Count > 0)
        {
            <div class="backup-list">
                @foreach (var backup in _backups)
                {
                    <div class="backup-list-item">
                        <span>@backup.Timestamp.ToLocalTime().ToString("g") — @((backup.SizeBytes / 1024.0).ToString("F1")) KB</span>
                        <span class="backup-device-tag">@backup.DeviceId</span>
                        <button class="download-btn backup-restore-btn" @onclick="() => BeginRestore(backup.DeviceId, backup.Id)">
                            @L("Restore")
                        </button>
                    </div>
                }
            </div>
        }
        else if (_backups != null && _backups.Count == 0)
        {
            <p class="backup-empty">@L("No_Backups_Found")</p>
        }

        @if (_devices != null && _devices.Count > 1)
        {
            <hr class="backup-divider" />
            <div class="backup-field">
                <label>@L("Sync_From_Device")</label>
                <div class="backup-input-row">
                    <select class="language-dropdown" @bind="_selectedSyncDevice">
                        <option value="">--</option>
                        @foreach (var device in _devices.Where(d => d != _deviceId))
                        {
                            <option value="@device">@device</option>
                        }
                    </select>
                    <button class="download-btn" @onclick="SyncFromDeviceAsync"
                            disabled="@(string.IsNullOrEmpty(_selectedSyncDevice) || _isRestoring)">
                        @L("Restore_Latest")
                    </button>
                </div>
            </div>
        }

        <hr class="backup-divider" />

        <div class="backup-field">
            <label class="debug-checkbox-label">
                <input type="checkbox" checked="@_autoBackupEnabled" @onchange="ToggleAutoBackup" />
                <span>@L("Auto_Backup")</span>
            </label>
        </div>
        @if (_autoBackupEnabled)
        {
            <div class="backup-field">
                <label>@L("Auto_Backup_Interval")</label>
                <select class="language-dropdown" @bind="AutoBackupInterval">
                    <option value="15">15 min</option>
                    <option value="30">30 min</option>
                    <option value="60">1 h</option>
                    <option value="120">2 h</option>
                    <option value="360">6 h</option>
                    <option value="720">12 h</option>
                    <option value="1440">24 h</option>
                </select>
            </div>
        }

        <div class="backup-field">
            <label class="debug-checkbox-label">
                <input type="checkbox" checked="@_backupOnChangeEnabled" @onchange="ToggleBackupOnChange" />
                <span>@L("Backup_On_Change")</span>
            </label>
            <p class="backup-hint">@L("Backup_On_Change_Description")</p>
        </div>
    </div>
</div>

<style>
