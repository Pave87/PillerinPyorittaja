    margin-bottom: 2rem;
    }

    .today-taken-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    }

    .taken-dose-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem;
    background-color: var(--panel-background);
    border-radius: 8px;
    border-left: 4px solid var(--row-accent-border);
    }
    .run-out-button {
    padding: 0.5rem 0.25rem;
    background-color: var(--button-delete-background); /* Red color */
    color: white;
    border: none;
    border-radius: 4px;
    cursor: default; /* No pointer cursor to indicate no action */
