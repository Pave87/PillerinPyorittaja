    // New method to handle upcoming dose taking with confirmation when needed
    private async Task HandleUpcomingDoseTake(int productId, int dosageId, double amountTaken, DateTime scheduledTime, string productName)
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log($"HandleUpcomingDoseTake called for productId={productId}, dosageId={dosageId}, amountTaken={amountTaken}, scheduledTime={scheduledTime}");
            try
            {
                if (IsFarIntoFuture(scheduledTime))
                {
                    // Show in-page confirmation popup for doses more than 3 hours in the future
                    await ShowConfirmationPopup(productId, dosageId, amountTaken, scheduledTime, productName);
                }
                else
                {
                    // Take the dose immediately for doses less than 3 hours away
                    await TakeProductDoseFromDosage(productId, dosageId, amountTaken);
                }
            }
            catch (Exception ex)
            {
                LoggerService.Log(ex);
            }
        }
    }

    // Shows the in-page confirmation popup
    private async Task ShowConfirmationPopup(int productId, int dosageId, double amountTaken, DateTime scheduledTime, string productName)
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log($"ShowConfirmationPopup called for productId={productId}, dosageId={dosageId}, amountTaken={amountTaken}, scheduledTime={scheduledTime}");
            pendingConfirmation = new PendingConfirmation
                {
                    ProductId = productId,
                    DosageId = dosageId,
                    AmountTaken = amountTaken,
                    NextDoseTime = scheduledTime,
                    ProductName = productName
                };

            // First set the popup to be rendered
            showConfirmationPopup = true;

            // Force immediate UI update
            StateHasChanged();

            // Use a small delay before showing the animation to ensure DOM has updated
            await Task.Delay(50);

            // Then make it visible with animation
            isConfirmationPopupVisible = true;
            StateHasChanged();
        }
    }

    // Hides the in-page confirmation popup
    private async Task HideConfirmationPopup()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("HideConfirmationPopup called");
            // Start the hiding animation
            isConfirmationPopupVisible = false;
            StateHasChanged();

            // Wait for animation to complete
            await Task.Delay(300);

            // Remove from DOM
            showConfirmationPopup = false;
            StateHasChanged();
        }
    }

