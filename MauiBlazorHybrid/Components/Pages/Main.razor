@page "/"
@using MauiBlazorHybrid.Models
@using MauiBlazorHybrid.Services
@using Microsoft.JSInterop
@using CommunityToolkit.Maui.Alerts
@using CommunityToolkit.Maui.Core
@using CommunityToolkit.Maui.Views
@inject IProductService ProductService
@inject INotificationService NotificationService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inherits MauiBlazorHybrid.Extensions.LocalizeComponent

@if (showVersionPopup)
{
    <div class="popup-overlay @(isVersionPopupVisible ? "overlay-visible" : "")"></div>
    <div class="in-page-popup @(isVersionPopupVisible ? "popup-visible" : "")">
        <div class="popup-header">
            <span class="popup-title">@L("Update_Notes")</span>
            <button class="popup-close" @onclick="HideVersionPopup">×</button>
        </div>
        <div class="popup-body">
            <h3>Version 0.3 päivitykset</h3>
            <ul>
                <li>Kun otat annoksen tulee pieni ilmoitus että annos otettu</li>
                <li>Jos koitat ottaa annosta joka yli 3h tulevaisuudessa kysytään vahvistus</li>
                <li>Tuotteen poisto vahvistus popup korjattu</li>
                <li>Tuotteelta voi poistaa yksittäisen annoksen ajoituksen</li>
                <li>Korjattu annosten aikataulujen laskentaa</li>
                <li>Historia sivulla voit katsoa/poistaa tapahtumia</li>
            </ul>
        </div>
        <button class="take-product-button" @onclick="HideVersionPopup">@L("Close")</button>
    </div>
}

@if (showConfirmationPopup)
{
    <div class="popup-overlay @(isConfirmationPopupVisible ? "overlay-visible" : "")" @onclick="HideConfirmationPopup"></div>
    <div class="in-page-popup @(isConfirmationPopupVisible ? "popup-visible" : "")">
        <div class="popup-header">
            <span class="popup-title">@L("Early_Dose_Confirmation")</span>
            <button class="popup-close" @onclick="HideConfirmationPopup">×</button>
        </div>
        <div class="popup-body">
            <p>
                @LF("Early_Dose_Message", new Dictionary<string, object> {
            { "productName", pendingConfirmation.ProductName },
            { "scheduledTime", FormatNextDoseTime(pendingConfirmation.NextDoseTime) }
            })
            </p>
            <div class="popup-actions">
                <button class="popup-button-no" @onclick="HideConfirmationPopup">@L("No")</button>
                <button class="popup-button-yes" @onclick="ConfirmTakeDose">@L("Yes")</button>
            </div>
        </div>
    </div>
}

@if (!_permissionGranted)
{
    <div class="alert alert-warning">
        <p>@L("Notifications_Not_Enabled")</p>
        <button class="permission-button" @onclick="RequestNotificationPermission">@L("Enable_Notifications")</button>
    </div>
}

@if (products == null)
{
    <p>@L("Loading")</p>
}
else if (!products.Any())
{
    <p>@L("No_Products_Added")</p>
    <button class="add-product-button" @onclick="NavigateToAddProduct">@L("Add_New_Product")</button>
}
else
{
    @if (missedDosages.Any())
    {
        <div class="missed-doses">
            <h2>@L("Missed_Doses")</h2>
            <div class="missed-doses-list">
                @foreach (var missedDosage in missedDosages.OrderBy(d => d.ScheduledTime).Take(5))
                {
                    var product = products.FirstOrDefault(p => p.Id == missedDosage.ProductId);
                    var dosage = product?.Dosages.FirstOrDefault(d => d.Id == missedDosage.DosageId);

                    if (product != null && dosage != null)
                    {
                        <div class="missed-dose-item">
                            <div class="dose-info">
                                <span class="product-name">@product.Name</span>
                                <span class="dose-detail">@dosage.AmountTaken @product.Unit</span>
                            </div>
                            <div class="dose-time">
                                <span class="missed-text">@FormatMissedDoseTime(missedDosage.ScheduledTime)</span>
                            </div>
                            <div class="dose-actions">
                                <button class="take-product-button" @onclick="() => TakeMissedDosage(product.Id, dosage.Id, missedDosage.Id, dosage.AmountTaken)">@L("Take_Now")</button>
                                <button class="skip-product-button" @onclick="() => SkipMissedDosage(product.Id, missedDosage.Id)">@L("Skip")</button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    <div class="upcoming-doses">
        <h2>@L("Upcoming_Doses")</h2>
        @if (upcomingDoses.Any())
        {
            <div class="upcoming-doses-list">
                @foreach (var dose in upcomingDoses.OrderBy(d => d.NextDoseTime).Take(5))
                {
                    <div class="upcoming-dose-item @(IsRecentlyDue(dose.NextDoseTime) ? "recent_due" : "")">
                        <div class="dose-info">
                            <span class="product-name">@dose.ProductName</span>
                            <div class="dose-combined-info">
                                <span class="dose-detail">@dose.AmountTaken @dose.Unit</span>
                                @if (IsRecentlyDue(dose.NextDoseTime))
                                {
                                    <span class="due-text">@L("Due_Now")</span>
                                }
                                else
                                {
                                    <span class="dose-time-info">@FormatNextDoseTime(dose.NextDoseTime)</span>
                                }
                            </div>
                        </div>
                        <button class="take-product-button" @onclick="() => HandleUpcomingDoseTake(dose.ProductId, dose.DosageId, dose.AmountTaken, dose.NextDoseTime, dose.ProductName)">@L("Take_Dose")</button>
                    </div>
                }
            </div>
        }
        else
        {
            <p>@L("No_Upcoming_Doses")</p>
        }
    </div>
}

