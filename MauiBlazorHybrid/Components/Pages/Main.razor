@code {
    private List<Product>? products;
    private bool _permissionGranted;
    private List<UpcomingDose> upcomingDoses = new();
    private List<MissedDosage> missedDosages = new();
    private List<MissedDose> missedDoses = new(); // Keep this for backward compatibility

    // In-page popup confirmation fields
    private bool showConfirmationPopup = false;
    private bool isConfirmationPopupVisible = false;
    private PendingConfirmation pendingConfirmation = new();

    // Version check fields
    private bool showVersionPopup = false;
    private bool isVersionPopupVisible = false;
    private const int EXPECTED_VERSION = 2; // The expected version number
    private string versionFilePath = string.Empty;

    // Class to store information about upcoming doses
    private class UpcomingDose
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public int DosageId { get; set; }
        public double AmountTaken { get; set; }
        public string Unit { get; set; } = string.Empty;
        public DateTime NextDoseTime { get; set; }
    }

    // Class to store information about missed doses (legacy)
    private class MissedDose
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public int DosageId { get; set; }
        public double AmountTaken { get; set; }
        public string Unit { get; set; } = string.Empty;
        public DateTime ScheduledTime { get; set; }
    }

    // Class to store pending confirmation details
    private class PendingConfirmation
    {
        public int ProductId { get; set; }
        public int DosageId { get; set; }
        public double AmountTaken { get; set; }
        public DateTime NextDoseTime { get; set; }
        public string ProductName { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        // Check version file first
        await CheckVersionFile();

        await CheckNotificationPermission();
        await LoadProducts();
        await LoadMissedDosages();
        await OrganizeUpcomingDoses();
    }

    private async Task CheckVersionFile()
    {
        try
        {
            // Get the app's local storage path
            string appDataPath = FileSystem.AppDataDirectory;
            versionFilePath = Path.Combine(appDataPath, "vers");
            
            bool fileExists = File.Exists(versionFilePath);
            bool versionMatches = false;
            
            if (fileExists)
            {
                // Read the version number from file
                string versionText = await File.ReadAllTextAsync(versionFilePath);
                if (int.TryParse(versionText.Trim(), out int currentVersion))
                {
                    versionMatches = (currentVersion == EXPECTED_VERSION);
                }
            }
            
            if (!fileExists || !versionMatches)
            {
                // Show the version popup
                await ShowVersionPopup();
                
                // Immediately update the version file (without waiting for user action)
                await UpdateVersionFile();
            }
        }
        catch (Exception ex)
        {
            // Handle any exceptions (optional)
            Console.WriteLine($"Error checking version file: {ex.Message}");
        }
    }
    
    private async Task UpdateVersionFile()
    {
        try
        {
            // Ensure directory exists
            string directory = Path.GetDirectoryName(versionFilePath);
            if (!string.IsNullOrEmpty(directory) && !Directory.Exists(directory))
            {
                Directory.CreateDirectory(directory);
            }
            
            // Write the expected version to file
            await File.WriteAllTextAsync(versionFilePath, EXPECTED_VERSION.ToString());
        }
        catch (Exception ex)
        {
            // Handle error (optional)
            Console.WriteLine($"Error writing version file: {ex.Message}");
        }
    }
    
    private async Task ShowVersionPopup()
    {
        // First set the popup to be rendered
        showVersionPopup = true;
        
        // Force immediate UI update
        StateHasChanged();
        
        // Use a small delay before showing the animation to ensure DOM has updated
        await Task.Delay(50);
        
        // Then make it visible with animation
        isVersionPopupVisible = true;
        StateHasChanged();
    }
    
    private async Task HideVersionPopup()
    {
        // Start the hiding animation
        isVersionPopupVisible = false;
        StateHasChanged();
        
        // Wait for animation to complete
        await Task.Delay(300);
        
        // Remove from DOM
        showVersionPopup = false;
        StateHasChanged();
    }

    private async Task LoadProducts()
    {
        products = await ProductService.GetProductsAsync();
    }

    private async Task LoadMissedDosages()
    {
        missedDosages = await ProductService.GetMissedDosagesAsync();
    }

    private async Task OrganizeUpcomingDoses()
    {
        upcomingDoses.Clear();

        if (products == null) return;

        foreach (var product in products)
        {
            DateTime? earliestDoseTime = null;
            DosageSchedule? earliestDosage = null;

            // Find the earliest upcoming dose for this product
            foreach (var dosage in product.Dosages)
            {
                // Always use the NextDose property from the dosage
                if (dosage.NextDose.HasValue)
                {
                    if (earliestDoseTime == null || dosage.NextDose.Value < earliestDoseTime.Value)
                    {
                        earliestDoseTime = dosage.NextDose.Value;
                        earliestDosage = dosage;
                    }
                }
            }

            // Add only the earliest dose for this product
            if (earliestDoseTime.HasValue && earliestDosage != null)
            {
                upcomingDoses.Add(new UpcomingDose
                    {
                        ProductId = product.Id,
                        ProductName = product.Name,
                        DosageId = earliestDosage.Id,
                        AmountTaken = earliestDosage.AmountTaken,
                        Unit = product.Unit,
                        NextDoseTime = earliestDoseTime.Value
                    });
            }
        }
    }

    private async Task CalculateMissedDoses()
    {
        // This method is kept as a fallback but shouldn't be needed anymore
        // since we now use the MissedDosages collection from each product
        missedDoses.Clear();

        if (products == null) return;

        DateTime now = DateTime.Now;

        foreach (var product in products)
        {
            foreach (var dosage in product.Dosages)
            {
                // Find when this dosage was last taken
                var lastTaken = product.History
                    .Where(h => h.DosageId == dosage.Id)
                    .OrderByDescending(h => h.Timestamp)
                    .FirstOrDefault();

                DateTime lastTakenDate = lastTaken?.Timestamp ?? DateTime.MinValue;

                // Find all missed doses since last taken
                List<DateTime> missedDoseTimes = new();

                // Calculate based on frequency
                if (dosage.Frequency == "Days")
                {
                    // For daily dosages: check every 'repetition' days from the last taken date
                    DateTime checkDate = lastTaken == null ? DateTime.Now.Date.AddDays(-30) : lastTaken.Timestamp.Date;

                    while (checkDate < now.Date)
                    {
                        checkDate = checkDate.AddDays(dosage.Repetition);

                        if (checkDate >= now.Date) break;

                        // Create a datetime with the scheduled time on this date
                        if (dosage.Time.HasValue)
                        {
                            DateTime scheduledDateTime = new DateTime(
                                checkDate.Year,
                                checkDate.Month,
                                checkDate.Day,
                                dosage.Time.Value.Hour,
                                dosage.Time.Value.Minute,
                                0
                            );

                            // If this scheduled time is in the past but not taken, it's missed
                            if (scheduledDateTime < now && !IsDosageTaken(product, dosage.Id, scheduledDateTime))
                            {
                                missedDoseTimes.Add(scheduledDateTime);
                            }
                        }
                    }
                }
                else if (dosage.Frequency == "Weeks" && dosage.SelectedDays?.Any() == true)
                {
                    // For weekly dosages: check each selected day since last taken
                    DateTime checkDate = lastTaken == null ? DateTime.Now.Date.AddDays(-60) : lastTaken.Timestamp.Date;

                    // Loop through dates
                    for (DateTime date = checkDate; date < now.Date; date = date.AddDays(1))
                    {
                        // Check if this is a selected day of the week
                        string dayCode = date.DayOfWeek switch
                        {
                            DayOfWeek.Monday => "Mon",
                            DayOfWeek.Tuesday => "Tue",
                            DayOfWeek.Wednesday => "Wed",
                            DayOfWeek.Thursday => "Thu",
                            DayOfWeek.Friday => "Fri",
                            DayOfWeek.Saturday => "Sat",
                            DayOfWeek.Sunday => "Sun",
                            _ => ""
                        };

                        if (dosage.SelectedDays.Contains(dayCode))
                        {
                            // Also check for repetition pattern (e.g., every 2 weeks)
                            // Calculate the week number since the epoch
                            int weekNumber = (int)Math.Floor((date - DateTime.MinValue).TotalDays / 7);

                            // Check if this week matches the repetition pattern
                            if (weekNumber % dosage.Repetition == 0)
                            {
                                // Create a datetime with the scheduled time on this date
                                if (dosage.Time.HasValue)
                                {
                                    DateTime scheduledDateTime = new DateTime(
                                        date.Year,
                                        date.Month,
                                        date.Day,
                                        dosage.Time.Value.Hour,
                                        dosage.Time.Value.Minute,
                                        0
                                    );

                                    // If this scheduled time is in the past but not taken, it's missed
                                    if (scheduledDateTime < now && !IsDosageTaken(product, dosage.Id, scheduledDateTime))
                                    {
                                        missedDoseTimes.Add(scheduledDateTime);
                                    }
                                }
                            }
                        }
                    }
                }

                // Add missed doses to the list (limit to recent misses to avoid overwhelming the UI)
                foreach (var missedTime in missedDoseTimes.OrderByDescending(t => t).Take(3))
                {
                    missedDoses.Add(new MissedDose
                        {
                            ProductId = product.Id,
                            ProductName = product.Name,
                            DosageId = dosage.Id,
                            AmountTaken = dosage.AmountTaken,
                            Unit = product.Unit,
                            ScheduledTime = missedTime
                        });
                }
            }
        }

        // Take the most recent missed doses
        missedDoses = missedDoses.OrderByDescending(d => d.ScheduledTime).Take(10).ToList();
    }

    private bool IsDosageTaken(Product product, int dosageId, DateTime scheduledTime)
    {
        // Check if there's a history entry for this dosage within a reasonable time window (+/- 2 hours)
        var startWindow = scheduledTime.AddHours(-2);
        var endWindow = scheduledTime.AddHours(2);

        return product.History.Any(h =>
            h.DosageId == dosageId &&
            h.Timestamp >= startWindow &&
            h.Timestamp <= endWindow);
    }

    private bool IsRecentlyDue(DateTime doseTime)
    {
        // Consider a dose "recently due" if it's scheduled for the past hour
        TimeSpan timeDiff = DateTime.Now - doseTime;
        return timeDiff > TimeSpan.Zero && timeDiff < TimeSpan.FromHours(1);
    }

    // Check if dose is far in the future (more than 3 hours)
    private bool IsFarIntoFuture(DateTime doseTime)
    {
        // Check if the dose is scheduled for more than 3 hours in the future
        TimeSpan timeDiff = doseTime - DateTime.Now;
        return timeDiff > TimeSpan.FromHours(3);
    }

    private string FormatNextDoseTime(DateTime nextDose)
    {
        DateTime now = DateTime.Now;

        // If it's today
        if (nextDose.Date == now.Date)
        {
            return $"{L("Today")} {nextDose.ToString("HH:mm")}";
        }
        // If it's tomorrow
        else if (nextDose.Date == now.Date.AddDays(1))
        {
            return $"{L("Tomorrow")} {nextDose.ToString("HH:mm")}";
        }
        // If it's within the next week
        else if ((nextDose.Date - now.Date).TotalDays < 7)
        {
            return $"{L(nextDose.ToString("dddd"))} {nextDose.ToString("HH:mm")}";
        }
        // Otherwise show the full date
        else
        {
            return nextDose.ToString("d MMM") + " " + nextDose.ToString("HH:mm");
        }
    }

    private string FormatMissedDoseTime(DateTime missedTime)
    {
        DateTime now = DateTime.Now;
        TimeSpan timeSince = now - missedTime;

        if (timeSince.TotalDays < 1)
        {
            // Less than a day ago - show hours
            int hours = (int)timeSince.TotalHours;
            return $"{hours} {(hours == 1 ? L("Hour_Ago") : L("Hours_Ago"))}";
        }
        else if (timeSince.TotalDays < 7)
        {
            // Less than a week ago - show days
            int days = (int)timeSince.TotalDays;
            return $"{days} {(days == 1 ? L("Day_Ago") : L("Days_Ago"))}";
        }
        else
        {
            // More than a week ago - show date
            return missedTime.ToString("d MMM");
        }
    }

    private async Task CheckNotificationPermission()
    {
        _permissionGranted = await NotificationService.RequestPermissionAsync();
        StateHasChanged();
    }

    private async Task RequestNotificationPermission()
    {
        _permissionGranted = await NotificationService.RequestPermissionAsync();
        StateHasChanged();
    }

    private void NavigateToAddProduct()
    {
        NavigationManager.NavigateTo("/addproduct");
    }

    // New method to handle upcoming dose taking with confirmation when needed
    private async Task HandleUpcomingDoseTake(int productId, int dosageId, double amountTaken, DateTime scheduledTime, string productName)
    {
        if (IsFarIntoFuture(scheduledTime))
        {
            // Show in-page confirmation popup for doses more than 3 hours in the future
            await ShowConfirmationPopup(productId, dosageId, amountTaken, scheduledTime, productName);
        }
        else
        {
            // Take the dose immediately for doses less than 3 hours away
            await TakeProductDoseFromDosage(productId, dosageId, amountTaken);
        }
    }

    // Shows the in-page confirmation popup
    private async Task ShowConfirmationPopup(int productId, int dosageId, double amountTaken, DateTime scheduledTime, string productName)
    {
        pendingConfirmation = new PendingConfirmation
            {
                ProductId = productId,
                DosageId = dosageId,
                AmountTaken = amountTaken,
                NextDoseTime = scheduledTime,
                ProductName = productName
            };

        // First set the popup to be rendered
        showConfirmationPopup = true;

        // Force immediate UI update
        StateHasChanged();

        // Use a small delay before showing the animation to ensure DOM has updated
        await Task.Delay(50);

        // Then make it visible with animation
        isConfirmationPopupVisible = true;
        StateHasChanged();
    }

    // Hides the in-page confirmation popup
    private async Task HideConfirmationPopup()
    {
        // Start the hiding animation
        isConfirmationPopupVisible = false;
        StateHasChanged();

        // Wait for animation to complete
        await Task.Delay(300);

        // Remove from DOM
        showConfirmationPopup = false;
        StateHasChanged();
    }

    // Confirms taking the dose from the popup
    private async Task ConfirmTakeDose()
    {
        await TakeProductDoseFromDosage(
            pendingConfirmation.ProductId,
            pendingConfirmation.DosageId,
            pendingConfirmation.AmountTaken);

        await HideConfirmationPopup();
    }

    private async Task TakeProductDoseFromDosage(int productId, int dosageId, double amountTaken)
    {
        var success = await ProductService.TakeProductDoseAsync(productId, amountTaken, dosageId);

        if (success)
        {
            // Show toast notification for successful dose taking
            var toast = Toast.Make(L("Dose_Taken_Successfully"));
            await toast.Show();
        }

        // Refresh the product list to show updated quantities and recalculated next dose times
        await LoadProducts();
        await LoadMissedDosages();
        await OrganizeUpcomingDoses();
    }

    private async Task TakeMissedDosage(int productId, int dosageId, int missedDosageId, double amountTaken)
    {
        var success = await ProductService.TakeMissedDosage(productId, missedDosageId, amountTaken);

        if (success)
        {
            var product = products?.FirstOrDefault(p => p.Id == productId);
            if (product != null)
            {
                // Show toast notification for successful missed dose taking
                string message = string.Format(L("Product_Dose_Taken"), product.Name);
                var toast = Toast.Make(message, ToastDuration.Short, 14);
                await toast.Show();
            }
        }

        // Refresh the data
        await LoadProducts();
        await LoadMissedDosages();
        await OrganizeUpcomingDoses();
    }

    private async Task SkipMissedDosage(int productId, int missedDosageId)
    {
        // Find the product
        var product = products?.FirstOrDefault(p => p.Id == productId);
        if (product == null) return;

        var success = await ProductService.SkipMissedDosageAsync(productId, missedDosageId);

        if (success)
        {
            // Show toast notification for skipping the dose
            string message = string.Format(L("Dose_Skipped"), product.Name);
            var toast = Toast.Make(message, ToastDuration.Short, 14);
            await toast.Show();
        }

        // Refresh the data
        await LoadProducts();
        await LoadMissedDosages();
        await OrganizeUpcomingDoses();
    }

    private async Task SkipMissedDose(MissedDose missedDose)
    {
        // This is the legacy method, kept for backward compatibility
        var skipHistory = new UsageHistory
            {
                ProductId = missedDose.ProductId,
                DosageId = missedDose.DosageId,
                Timestamp = missedDose.ScheduledTime,
                AmountTaken = 0, // 0 indicates a skipped dose
                Event = EventType.Skipped
            };

        await ProductService.AddProductHistoryManuallyAsync(skipHistory);

        // Recalculate doses
        await LoadProducts();
        await LoadMissedDosages();
        await OrganizeUpcomingDoses();
        await CalculateMissedDoses();
    }
}

