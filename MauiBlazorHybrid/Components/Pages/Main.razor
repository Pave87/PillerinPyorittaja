</style>

@code {
    private List<Product>? products;
    private bool _permissionGranted;
    private List<UpcomingDose> upcomingDoses = new();
    private List<MissedDosage> missedDosages = new();
    private List<MissedDose> missedDoses = new(); // Keep this for backward compatibility
    private List<UsageHistory> takenDoses = new();
    private bool ShowTodayTaken = false;

    // In-page popup confirmation fields
    private bool showConfirmationPopup = false;
    private bool isConfirmationPopupVisible = false;
    private PendingConfirmation pendingConfirmation = new();

    // Version check fields
    private bool showVersionPopup = false;
    private bool isVersionPopupVisible = false;
    private const string EXPECTED_VERSION = "1.1.0"; // The expected version number
    private string versionFilePath = string.Empty;

    private string[]? releaseNotes;
    private string version = null;

    // Class to store information about upcoming doses
    private class UpcomingDose
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public int DosageId { get; set; }
        public double AmountTaken { get; set; }
        public string Unit { get; set; } = string.Empty;
        public DateTime NextDoseTime { get; set; }
    }

    // Class to store information about missed doses (legacy)
    private class MissedDose
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public int DosageId { get; set; }
        public double AmountTaken { get; set; }
        public string Unit { get; set; } = string.Empty;
        public DateTime ScheduledTime { get; set; }
    }

    // Class to store pending confirmation details
    private class PendingConfirmation
    {
        public int ProductId { get; set; }
        public int DosageId { get; set; }
        public double AmountTaken { get; set; }
        public DateTime NextDoseTime { get; set; }
        public string ProductName { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("OnInitializedAsync started");
            try
            {
                // Check version file first
                await CheckVersionFile();

                var settingsService = MauiProgram.Services.GetService<ISettingsService>();
                ShowTodayTaken = settingsService?.ShowTodayTaken ?? false;

                await CheckNotificationPermission();
                await LoadProducts();
                await LoadMissedDosages();
                if (ShowTodayTaken)
                {
                    await LoadTakenDoses();
                }
                await OrganizeUpcomingDoses();

                await base.OnInitializedAsync();
            
                // Check if we have a pending reminder configuration from a notification
                CheckForPendingReminderConfig();
            }
            catch (Exception ex)
            {
                LoggerService.Log(ex);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log($"OnAfterRenderAsync called, firstRender={firstRender}");
            try
            {
                await base.OnAfterRenderAsync(firstRender);
            
                if (firstRender)
                {
                    // Also check after first render to make sure the app is fully loaded
                    CheckForPendingReminderConfig();
                }
            }
            catch (Exception ex)
            {
                LoggerService.Log(ex);
            }
        }
    }

    private async Task TakeConsumeByNeedProduct(int productId, double amount)
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log($"TakeConsumeByNeedProduct called for productId={productId}, amount={amount}");
            try
            {
                var success = await ProductService.TakeProductDoseAsync(productId, amount);

                if (success)
                {
                    var product = products?.FirstOrDefault(p => p.Id == productId);
                    if (product != null)
                    {
                        // Show toast notification for successful dose taking
                        string message = string.Format(L("Product_Dose_Taken"), product.Name);
                        var toast = Toast.Make(message, ToastDuration.Short, 14);
                        await toast.Show();
                    }
                }

                // Refresh the product list to show updated quantities
                await LoadProducts();
            }
            catch (Exception ex)
            {
                LoggerService.Log(ex);
            }
        }
    }

    private async Task LoadTakenDoses()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("LoadTakenDoses called");
            try
            {
                var allHistory = await ProductService.GetAllProductHistoryAsync();
                var now = DateTime.Now;
                takenDoses = allHistory
                    .Where(h => h.Timestamp >= now.AddHours(-24) && h.Event == EventType.Taken)
                    .ToList();
            }
            catch (Exception ex)
            {
                LoggerService.Log(ex);
            }
        }
    }

    private void CheckForPendingReminderConfig()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("CheckForPendingReminderConfig called");
    #if ANDROID
            if (MauiBlazorHybrid.MainActivity.HasPendingReminderConfig)
            {
                int productId = MauiBlazorHybrid.MainActivity.PendingProductId;
                int dosageId = MauiBlazorHybrid.MainActivity.PendingDosageId;
                
                if (productId > 0 && dosageId > 0)
                {
                    // Navigate to the reminder configuration page
                    NavigationManager.NavigateTo($"/reminderconfig/{productId}/{dosageId}");
                    
                    // Clear the pending configuration to avoid duplicate navigation
                    MauiBlazorHybrid.MainActivity.ClearPendingReminderConfig();
                }
            }
    #endif
        }
    }

    private async Task CheckVersionFile()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("CheckVersionFile called");
            try
            {
                // Get the app's local storage path
                string appDataPath = FileSystem.AppDataDirectory;
                versionFilePath = Path.Combine(appDataPath, "vers");
                
                bool fileExists = File.Exists(versionFilePath);
                bool versionMatches = false;
                
                if (fileExists)
                {
                    // Read the version number from file
                    string versionText = await File.ReadAllTextAsync(versionFilePath);
                    versionMatches = (versionText == EXPECTED_VERSION);
                }
                
                if (!fileExists || !versionMatches)
                {
                    // Show the version popup
                    await ShowVersionPopup();
                    
                    // Immediately update the version file (without waiting for user action)
                    await UpdateVersionFile();
                }
            }
            catch (Exception ex)
            {
                // Handle any exceptions (optional)
                LoggerService.Log(ex);
            }
        }
    }
    
    private async Task UpdateVersionFile()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("UpdateVersionFile called");
            try
            {
                // Ensure directory exists
                string directory = Path.GetDirectoryName(versionFilePath);
                if (!string.IsNullOrEmpty(directory) && !Directory.Exists(directory))
                {
                    Directory.CreateDirectory(directory);
                }
                
                // Write the expected version to file
                await File.WriteAllTextAsync(versionFilePath, EXPECTED_VERSION);
            }
            catch (Exception ex)
            {
                // Handle error (optional)
                LoggerService.Log(ex);
            }
        }
    }
    
    private async Task ShowVersionPopup()
    {
        await LoadReleaseNotesAsync();
        using (CallContext.BeginCall())
        {
            LoggerService.Log("ShowVersionPopup called");
            // First set the popup to be rendered
            showVersionPopup = true;
            
            // Force immediate UI update
            StateHasChanged();
            
            // Use a small delay before showing the animation to ensure DOM has updated
            await Task.Delay(50);
            
            // Then make it visible with animation
            isVersionPopupVisible = true;
            StateHasChanged();
        }
    }
    
    private async Task HideVersionPopup()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("HideVersionPopup called");
            // Start the hiding animation
            isVersionPopupVisible = false;
            StateHasChanged();
            
            // Wait for animation to complete
            await Task.Delay(300);
            
            // Remove from DOM
            showVersionPopup = false;
            StateHasChanged();
        }
    }

    private async Task LoadProducts()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("LoadProducts called");
            try
            {
                products = await ProductService.GetProductsAsync();
            }
            catch (Exception ex)
            {
                LoggerService.Log(ex);
            }
        }
    }

    private async Task LoadMissedDosages()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("LoadMissedDosages called");
            try
            {
                missedDosages = await ProductService.GetMissedDosagesAsync();
            }
            catch (Exception ex)
            {
                LoggerService.Log(ex);
            }
        }
    }

    private async Task OrganizeUpcomingDoses()
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log("OrganizeUpcomingDoses called");
            upcomingDoses.Clear();

            if (products == null) return;

            foreach (var product in products)
            {
                DateTime? earliestDoseTime = null;
                DosageSchedule? earliestDosage = null;

                // Find the earliest upcoming dose for this product
                foreach (var dosage in product.Dosages)
                {
                    // Always use the NextDose property from the dosage
                    if (dosage.NextDose.HasValue)
                    {
                        if (earliestDoseTime == null || dosage.NextDose.Value < earliestDoseTime.Value)
                        {
                            earliestDoseTime = dosage.NextDose.Value;
                            earliestDosage = dosage;
                        }
                    }
                }

                // Add only the earliest dose for this product
                if (earliestDoseTime.HasValue && earliestDosage != null)
                {
                    upcomingDoses.Add(new UpcomingDose
                    {
                        ProductId = product.Id,
                        ProductName = product.Name,
                        DosageId = earliestDosage.Id,
                        AmountTaken = earliestDosage.AmountTaken,
                        Unit = product.Unit,
                        NextDoseTime = earliestDoseTime.Value
                    });
                }
            }
        }
    }

    private bool IsRecentlyDue(DateTime doseTime)
    {
        // Consider a dose "recently due" if it's scheduled for the past hour
        TimeSpan timeDiff = DateTime.Now - doseTime;
        return timeDiff > TimeSpan.Zero && timeDiff < TimeSpan.FromHours(1);
    }

    // Check if dose is far in the future (more than 3 hours)
    private bool IsFarIntoFuture(DateTime doseTime)
    {
        // Check if the dose is scheduled for more than 3 hours in the future
        TimeSpan timeDiff = doseTime - DateTime.Now;
        return timeDiff > TimeSpan.FromHours(3);
    }

    private string FormatNextDoseTime(DateTime nextDose)
    {
        DateTime now = DateTime.Now;

        // If it's today
        if (nextDose.Date == now.Date)
        {
            return $"{L("Today")} {nextDose.ToString("HH:mm")}";
        }
        // If it's tomorrow
        else if (nextDose.Date == now.Date.AddDays(1))
        {
            return $"{L("Tomorrow")} {nextDose.ToString("HH:mm")}";
        }
        // If it's within the next week
        else if ((nextDose.Date - now.Date).TotalDays < 7)
        {
            return $"{L(nextDose.ToString("dddd"))} {nextDose.ToString("HH:mm")}";
        }
        // Otherwise show the full date
        else
        {
            return nextDose.ToString("d MMM") + " " + nextDose.ToString("HH:mm");
        }
    }

    private string FormatMissedDoseTime(DateTime missedTime)
    {
        DateTime now = DateTime.Now;
        TimeSpan timeSince = now - missedTime;

        if (timeSince.TotalDays < 1)
        {
            // Less than a day ago - show hours
            int hours = (int)timeSince.TotalHours;
            return $"{hours} {(hours == 1 ? L("Hour_Ago") : L("Hours_Ago"))}";
        }
        else if (timeSince.TotalDays < 7)
        {
            // Less than a week ago - show days
            int days = (int)timeSince.TotalDays;
            return $"{days} {(days == 1 ? L("Day_Ago") : L("Days_Ago"))}";
        }
        else
        {
            // More than a week ago - show date
            return missedTime.ToString("d MMM");
        }
    }

