    private async Task SkipMissedDose(MissedDose missedDose)
    {
        using (CallContext.BeginCall())
        {
            LoggerService.Log($"SkipMissedDose (legacy) called for productId={missedDose.ProductId}, dosageId={missedDose.DosageId}");
            try
            {
                // This is the legacy method, kept for backward compatibility
                var skipHistory = new UsageHistory
                    {
                        ProductId = missedDose.ProductId,
                        DosageId = missedDose.DosageId,
                        Timestamp = missedDose.ScheduledTime,
                        AmountTaken = 0, // 0 indicates a skipped dose
                        Event = EventType.Skipped
                    };

                await ProductService.AddProductHistoryManuallyAsync(skipHistory);

                // Recalculate doses
                await LoadProducts();
                await LoadMissedDosages();
                await OrganizeUpcomingDoses();
            }
            catch (Exception ex)
            {
                LoggerService.Log(ex);
            }
        }
    }

    private async Task LoadReleaseNotesAsync()
    {
        try
        {
            var lang = LocalizationService.CurrentCulture.StartsWith("fi", StringComparison.OrdinalIgnoreCase) ? "fi" : "en";
            Stream stream;
            try
            {
                stream = await FileSystem.OpenAppPackageFileAsync($"ReleaseNotes.{lang}.txt");
            }
            catch
            {
                stream = await FileSystem.OpenAppPackageFileAsync("ReleaseNotes.en.txt");
            }
            using var _stream = stream;
            using var reader = new StreamReader(stream, System.Text.Encoding.UTF8);
            var lines = new List<string>();
            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (line != null)
                    lines.Add(line);
            }

            if (lines.Count > 0)
            {
                version = lines[0];
                releaseNotes = lines.Skip(1).Where(l => !string.IsNullOrWhiteSpace(l)).ToArray();
            }
            else
            {
                version = null;
                releaseNotes = new[] { "Release notes not available." };
            }
        }
        catch
        {
            releaseNotes = new[] { "Release notes not available." };
        }
    }
