</div>

<style>
    .test-release-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem;
    }

    .text-block {
        background-color: #f8f9fa;
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        border-left: 4px solid #17a2b8;
    }

        .text-block h3 {
            margin-top: 0;
            color: #212529;
        }

    .button-container {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
    }

    .ok-button {
        padding: 0.75rem 2rem;
        background-color: #28a745;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 500;
        font-size: 1.1rem;
    }

        .ok-button:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            transition: all 0.2s ease;
        }
</style>

