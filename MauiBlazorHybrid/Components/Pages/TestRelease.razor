@page "/testrelease"
@using MauiBlazorHybrid.Services
@using Microsoft.Maui.Storage
@inject NavigationManager NavigationManager

<div class="test-release-container">

    <div class="text-block">
        <h3>@(version is not null ? $"Päivitys {version}" : "Päivitys")</h3>
    </div>

    <div class="text-block">
        <ul>
            @if (releaseNotes is not null)
            {
                foreach (var note in releaseNotes)
                {
                    <li>@((MarkupString)note)</li>
                }
            }
            else
            {
                <li>Loading release notes...</li>
            }
        </ul>
    </div>

</div>

<style>
    .test-release-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem;
    }

    .text-block {
        background-color: var(--panel-background);
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        border-left: 4px solid var(--row-accent-border);
    }

        .text-block h3 {
            margin-top: 0;
            color: var(--body-text);
        }

    .button-container {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
    }

    .ok-button {
        padding: 0.75rem 2rem;
        background-color: var(--button-save-background);
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 500;
        font-size: 1.1rem;
    }

        .ok-button:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            transition: all 0.2s ease;
        }
</style>

@code {
    private string[]? releaseNotes;
    private string version = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadReleaseNotesAsync();
    }

    private async Task LoadReleaseNotesAsync()
    {
        try
        {
            using var stream = await FileSystem.OpenAppPackageFileAsync("ReleaseNotes.txt");
            using var reader = new StreamReader(stream, System.Text.Encoding.UTF8);
            var lines = new List<string>();
            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (line != null)
                    lines.Add(line);
            }

            if (lines.Count > 0)
            {
                version = lines[0];
                releaseNotes = lines.Skip(1).Where(l => !string.IsNullOrWhiteSpace(l)).ToArray();
            }
            else
            {
                version = null;
                releaseNotes = new[] { "Release notes not available." };
            }
        }
        catch
        {
            releaseNotes = new[] { "Release notes not available." };
        }
    }
}
