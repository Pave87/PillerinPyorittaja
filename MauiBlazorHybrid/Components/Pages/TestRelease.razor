@page "/testrelease"
@using MauiBlazorHybrid.Services
@using Microsoft.Maui.Storage
@inject NavigationManager NavigationManager

<div class="test-release-container">
    <h2>Test Release Information</h2>

    <div class="text-block">
        <h3>Päivitys 0.2</h3>
    </div>

    <div class="text-block">
        <p>Ilmoituksien toimintaa korjattu. Ilmoitusten pitäisi nyt toimia sillonkin kun sovellus ei ole auki.</p>
        <p>Lisätty tämä ruutu.</p>
        <p>Luotu palaute kanava Discordiin. Voit liittyä tällä linkillä: <a href="https://discord.gg/tXQ8JXuz" target="_blank">https://discord.gg/tXQ8JXuz</a></p>
