@code {
    private List<Product> products = new();
    private List<UsageHistory> allHistory = new();
    private List<UsageHistory> filteredHistory = new();
    private int selectedProductId = 0; // 0 means "All Products"
    private int selectedDosageId = 0; // 0 means "All Dosages" for the selected product
    private Product? selectedProduct = null;

    // Custom popup state variables
    private bool showDeleteConfirmation = false;
    private bool isDeletePopupVisible = false;
    private int pendingDeleteHistoryId;
    private int pendingDeleteProductId;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await ApplyFilters();
    }

    private async Task LoadData()
    {
        products = await ProductService.GetProductsAsync();
        allHistory = await ProductService.GetAllProductHistoryAsync();
    }

    private async Task ApplyFilters()
    {
        // Update selectedProduct if productId changed
        if (selectedProductId > 0)
        {
            selectedProduct = products.FirstOrDefault(p => p.Id == selectedProductId);
        }
        else
        {
            selectedProduct = null;
            selectedDosageId = 0; // Reset dosage filter when "All Products" is selected
        }

        // Apply filters
        if (selectedProductId > 0)
        {
            if (selectedDosageId > 0)
            {
                // Filter by both product and specific dosage
                filteredHistory = allHistory
                    .Where(h => h.ProductId == selectedProductId && h.DosageId == selectedDosageId)
                    .OrderByDescending(h => h.Timestamp)
                    .ToList();
            }
            else
            {
                // Filter by product only
                filteredHistory = allHistory
                    .Where(h => h.ProductId == selectedProductId)
                    .OrderByDescending(h => h.Timestamp)
                    .ToList();
            }
        }
        else
        {
            // No filters - show all history
            filteredHistory = allHistory.OrderByDescending(h => h.Timestamp).ToList();
        }
    }

    private string GetProductName(int productId)
    {
        return products.FirstOrDefault(p => p.Id == productId)?.Name ?? $"Product {productId}";
    }

    private string GetProductUnit(int productId)
    {
        return products.FirstOrDefault(p => p.Id == productId)?.Unit ?? "";
    }

    private string FormatDosageInfo(DosageSchedule dosage)
    {
        string timeInfo = dosage.Time?.ToString("HH:mm") ?? "--:--";

        if (dosage.Frequency == "Days")
        {
            return $"{timeInfo}, every {dosage.Repetition} day(s)";
        }
        else if (dosage.Frequency == "Weeks" && dosage.SelectedDays?.Any() == true)
        {
            string days = string.Join(", ", dosage.SelectedDays);
            return $"{timeInfo}, {days}, every {dosage.Repetition} week(s)";
        }

        return $"{timeInfo}";
    }

    private string FormatEventType(EventType eventType)
    {
        return eventType switch
        {
            EventType.Taken => L("Taken"),
            EventType.Refilled => L("Refilled"),
            EventType.Created => L("Created"),
            EventType.Modified => L("Modified"),
            EventType.Removed => L("Removed"),
            EventType.Skipped => L("Skipped"),
            _ => eventType.ToString()
        };
    }

    private string GetEventTypeClass(EventType eventType)
    {
        return $"event-{eventType.ToString().ToLower()}";
    }

    // Show the custom delete confirmation popup
    private async Task ShowDeleteConfirmation(int historyId, int productId)
    {
        pendingDeleteHistoryId = historyId;
        pendingDeleteProductId = productId;

        // First set the popup to be rendered
        showDeleteConfirmation = true;

        // Force immediate UI update
        StateHasChanged();

        // Use a small delay to ensure DOM has been updated
        await Task.Delay(50);

        // Then make it visible with animation
        isDeletePopupVisible = true;
        StateHasChanged();
    }

    // Hide the custom delete confirmation popup
    private async Task HideDeleteConfirmation()
    {
        // Start the hiding animation
        isDeletePopupVisible = false;
        StateHasChanged();

        // Wait for animation to complete
        await Task.Delay(300);

        // Remove from DOM
        showDeleteConfirmation = false;
        StateHasChanged();
    }

    // Process the deletion after confirmation
    private async Task ConfirmDeleteHistoryRecord()
    {
        try
        {
            // Get the product
            var product = await ProductService.GetProductAsync(pendingDeleteProductId);

            if (product != null)
            {
                // Find and remove the history record
                var historyToRemove = product.History.FirstOrDefault(h => h.Id == pendingDeleteHistoryId);
                if (historyToRemove != null)
                {
                    product.History.Remove(historyToRemove);

                    // Save the updated product
                    await ProductService.UpdateProductAsync(product);

                    // Refresh the history list
                    await LoadData();
                    await ApplyFilters();
                    var toast = Toast.Make(L("History_Record_Deleted"), ToastDuration.Short);
                    await toast.Show();
                }
            }
        }
        catch (Exception ex)
        {
            var toast = Toast.Make($"{L("Error")}: {ex.Message}", ToastDuration.Long);
            await toast.Show();

        }
        finally
        {
            await HideDeleteConfirmation();
        }
    }
}
