@page "/history"
@using MauiBlazorHybrid.Models
@using MauiBlazorHybrid.Services
@using Microsoft.JSInterop
@using CommunityToolkit.Maui.Alerts
@using CommunityToolkit.Maui.Core
@inject IProductService ProductService
@inject IJSRuntime JS
@inherits MauiBlazorHybrid.Extensions.LocalizeComponent

<h3>@L("History")</h3>

@if (showDeleteConfirmation)
{
    <div class="popup-overlay @(isDeletePopupVisible ? "overlay-visible" : "")" @onclick="HideDeleteConfirmation"></div>
    <div class="in-page-popup @(isDeletePopupVisible ? "popup-visible" : "")">
        <div class="popup-header">
            <span class="popup-title">@L("Confirm_Delete_History")</span>
            <button class="popup-close" @onclick="HideDeleteConfirmation">×</button>
        </div>
        <div class="popup-body">
            <p>@L("Are_You_Sure_Delete_History_Record")</p>
            <div class="popup-actions">
                <button class="popup-button-no" @onclick="HideDeleteConfirmation">@L("No")</button>
                <button class="popup-button-yes" @onclick="ConfirmDeleteHistoryRecord">@L("Yes")</button>
            </div>
        </div>
    </div>
}

<div class="filter-container">
    <div class="filter-group">
        <label for="productFilter">@L("Product"):</label>
        <select id="productFilter" class="filter-select" @bind="selectedProductId">
            <option value="0">@L("All_Products")</option>
            @foreach (var product in products)
            {
                <option value="@product.Id">@product.Name</option>
            }
        </select>
    </div>

    <button class="filter-button" @onclick="ApplyFilters">@L("Apply_Filters")</button>
</div>

@if (filteredHistory == null)
{
    <p>@L("Loading")</p>
}
else if (!filteredHistory.Any())
{
    <p>@L("No_History_Found")</p>
}
else
{
    <div class="history-list">
        @foreach (var historyItem in filteredHistory)
        {
            <div class="history-item">
                <div class="history-product">
                    <span class="product-name">@GetProductName(historyItem.ProductId)</span>
                    @if (historyItem.Event == EventType.Taken)
                    {
                        <span class="history-amount">@historyItem.AmountTaken @GetProductUnit(historyItem.ProductId)</span>
                    }
                </div>
                <div class="history-time">
                    @if (historyItem.Event == EventType.Taken || historyItem.Event == EventType.Skipped)
                    {
                        <span class="history-time-value">@L("Taken"): @historyItem.Timestamp.ToString("d MMM yyyy HH:mm")</span>
                        <span class="history-schedule-time">@L("Scheduled"): @(historyItem.ScheduleTime?.ToString("d MMM yyyy HH:mm") ?? "--:--")</span>
                    }
                    else
                    {
                        <span class="history-time-value">@historyItem.Timestamp.ToString("d MMM yyyy HH:mm")</span>
                    }
                </div>
                <div class="history-event">
                    <button class="event-type-button @GetEventTypeClass(historyItem.Event)" @onclick="() => ShowDeleteConfirmation(historyItem.Id, historyItem.ProductId)">
                        @FormatEventType(historyItem.Event)
                    </button>
                </div>
            </div>
        }
    </div>
}

