@page "/addproduct"
@page "/addproduct/{Id:int?}"
@using MauiBlazorHybrid.Models
@using MauiBlazorHybrid.Services
@using MauiBlazorHybrid.Extensions
@inject IProductService ProductService
@inject NavigationManager NavigationManager
@inherits LocalizeComponent

<h1>@L(Id.HasValue ? "Edit_Product" : "Add_New_Product")</h1>

<form>
    <div class="form-group">
        <label for="productName">@L("Product_Name"):</label>
        <input id="productName" type="text" @bind="ProductName" class="form-control" />
    </div>

    <div class="form-group">
        <label for="productQuantity">@L("Quantity_Left"):</label>
        <input id="productQuantity" type="number" @bind="ProductQuantity" min="0" step="0.5" class="form-control" />
    </div>

    <div class="form-group">
        <label for="Unit">@L("Unit"):</label>
        <input id="Unit" type="text" @bind="Unit" class="form-control" />
    </div>

    <div class="form-group">
        <label for="amountPerPackage">@L("Products_Per_Package"):</label>
        <input id="amountPerPackage" type="number" @bind="AmountPerPackage" min="1" step="1" class="form-control" />
    </div>

    <h3>@L("Dosages")</h3>
    @foreach (var (dosage, index) in Dosages.Select((d, i) => (d, i)))
    {
        <div class="dosage-row">
            <div class="form-group">
                <label>@L("Time"):</label>
                <input type="time"
                       @bind="dosage.Time"
                       @bind:event="oninput"
                       class="form-control" />
            </div>

            <div class="form-group">
                <label>@L("Amount_Taken"):</label>
                <input type="number" @bind="dosage.AmountTaken" class="form-control" style="width: 100px;" step="0.5" min="0.5" />
            </div>

            <div class="form-group">
                <label>@L("Repetition"):</label>
                <input type="number" @bind="dosage.Repetition" class="form-control" style="width: 80px;" min="1" />
            </div>

            <div class="form-group">
                <label>@L("Frequency"):</label>
                <select @bind="dosage.Frequency" class="form-control">
                    <option value="Days">@L("Days")</option>
                    <option value="Weeks">@L("Weeks")</option>
                </select>
            </div>

            @if (dosage.Frequency == "Weeks")
            {
                <div class="weekday-selection">
                    <label>@L("Select_Weekdays"):</label>
                    <div class="weekday-checkboxes">
                        @foreach (var day in WeekDays)
                        {
                            <label class="weekday-checkbox">
                                <input type="checkbox"
                                       checked="@(dosage.SelectedDays?.Contains(day) ?? false)"
                                       @onchange="@(e => ToggleWeekday(dosage, day, (bool)e.Value))" />
                                @L(day)
                            </label>
                        }
                    </div>
                </div>
            }

            @if (index == Dosages.Count - 1)
            {
                <button type="button" class="btn-add-dosage" @onclick="AddNewDosageRow">@L("Add_Another_Dosage")</button>
            }
        </div>
    }

    @if (!Dosages.Any())
    {
        <button type="button" class="btn-add-dosage" @onclick="AddNewDosageRow">@L("Add_Dosage")</button>
    }

    <div class="form-actions">
        <button type="button" class="btn-submit" @onclick="HandleSubmit">@L(Id.HasValue ? "Save_Changes" : "Add_Product")</button>
        <button type="button" class="btn-cancel" @onclick="Cancel">@L("Cancel")</button>
    </div>
</form>

<style>
    form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 550px;
        margin: 0 auto;
        padding: 1rem;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    label {
        display: block;
        font-weight: bold;
        margin-bottom: 0.5rem;
    }

    .form-control {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 1rem;
    }

    .dosage-row {
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
        background-color: #f9f9f9;
    }

    .weekday-selection {
        margin-top: 1rem;
    }

    .weekday-checkboxes {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .weekday-checkbox {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        margin-right: 1rem;
    }

    .btn-add-dosage {
        display: block;
        padding: 0.5rem 1rem;
        background-color: #17a2b8;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        margin: 1rem 0;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn-submit, .btn-cancel {
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 500;
    }

    .btn-submit {
        background-color: #28a745;
        color: white;
    }

    .btn-cancel {
        background-color: #6c757d;
        color: white;
    }

    button:hover {
        opacity: 0.9;
    }
</style>

@code {
    [Parameter]
    public int? Id { get; set; }

    private string ProductName { get; set; } = string.Empty;
    private double ProductQuantity { get; set; } = 0;
    private double AmountPerPackage { get; set; } = 1;
    private string Unit { get; set; } = string.Empty;
    private List<DosageSchedule> Dosages { get; set; } = new();
    private readonly string[] WeekDays = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
    private int _nextDosageId = 1; // Track next dosage ID

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Id.HasValue)
            {
                var product = await ProductService.GetProductAsync(Id.Value);
                if (product != null)
                {
                    ProductName = product.Name;
                    ProductQuantity = product.Quantity;
                    AmountPerPackage = product.AmountPerPackage;
                    Unit = product.Unit;
                    Dosages = product.Dosages.Select(d => new DosageSchedule
                        {
                            Id = d.Id,
                            ProductId = d.ProductId,
                            Time = d.Time,
                            Repetition = d.Repetition,
                            Frequency = d.Frequency,
                            SelectedDays = d.SelectedDays,
                            AmountTaken = d.AmountTaken
                        }).ToList();

                    // Set the next dosage ID based on existing dosages
                    _nextDosageId = Dosages.Any() ? Dosages.Max(d => d.Id) + 1 : 1;
                }
                else
                {
                    NavigationManager.NavigateTo("/products");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading product: {ex.Message}");
            NavigationManager.NavigateTo("/products");
        }
    }

    private void AddNewDosageRow()
    {
        Dosages.Add(new DosageSchedule
            {
                Id = _nextDosageId++, // Assign incremental ID
                ProductId = Id ?? 0, // Set ProductId if we're editing an existing product
                Frequency = "Days",
                SelectedDays = new List<string>(),
                Repetition = 1,
                AmountTaken = 1.0
            });
        StateHasChanged();
    }

    private void ToggleWeekday(DosageSchedule dosage, string day, bool isChecked)
    {
        if (dosage.SelectedDays == null)
        {
            dosage.SelectedDays = new List<string>();
        }

        if (isChecked && !dosage.SelectedDays.Contains(day))
        {
            dosage.SelectedDays.Add(day);
        }
        else if (!isChecked && dosage.SelectedDays.Contains(day))
        {
            dosage.SelectedDays.Remove(day);
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(ProductName) || !Dosages.Any())
                return;

            if (Id.HasValue)
            {
                var existingProduct = await ProductService.GetProductAsync(Id.Value);
                if (existingProduct != null)
                {
                    existingProduct.Name = ProductName;
                    existingProduct.Quantity = ProductQuantity;
                    existingProduct.AmountPerPackage = AmountPerPackage;
                    existingProduct.Unit = Unit;

                    // Ensure all dosages have the correct ProductId
                    foreach (var dosage in Dosages)
                    {
                        dosage.ProductId = existingProduct.Id;
                    }

                    existingProduct.Dosages = Dosages;
                    await ProductService.UpdateProductAsync(existingProduct);
                }
            }
            else
            {
                var newProduct = new Product
                    {
                        Name = ProductName,
                        Quantity = ProductQuantity,
                        AmountPerPackage = AmountPerPackage,
                        Unit = Unit,
                        Dosages = new List<DosageSchedule>() // Initialize with empty list
                    };

                // Add the product first to get its ID
                var savedProduct = await ProductService.AddProductAsync(newProduct);

                // Update dosage IDs and ProductId
                foreach (var dosage in Dosages)
                {
                    dosage.ProductId = savedProduct.Id;
                }

                // Update the product with dosages
                savedProduct.Dosages = Dosages;
                await ProductService.UpdateProductAsync(savedProduct);
            }

            NavigationManager.NavigateTo("/manage");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving product: {ex.Message}");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/manage");
    }
}
